{
  "kind": "collectionType",
  "collectionName": "actualites",
  "info": {
    "singularName": "actualite",
    "pluralName": "actualites",
    "displayName": "actualite"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titre": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "string",
      "required": true
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "videos",
        "audios"
      ]
    },
    "contenu": {
      "type": "dynamiczone",
      "components": [
        "contenu.section"
      ]
    },
    "slug": {
      "type": "uid",
      "targetField": "titre",
      "required": true
    },
    "date_evenement": {
      "type": "date",
      "required": true
    }
  }
}
